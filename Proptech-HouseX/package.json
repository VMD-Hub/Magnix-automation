{
  "name": "housex",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev --webpack",
    "build": "next build --webpack",
    "start": "next start",
    "lint": "eslint",
    "test": "node --import tsx --test tests/**/*.test.ts",
    "db:generate": "prisma generate",
    "db:up": "docker compose up -d --wait",
    "db:down": "docker compose down",
    "db:push": "prisma db push",
    "db:migrate": "prisma migrate dev",
    "db:deploy": "prisma migrate deploy",
    "db:seed": "prisma db seed",
    "db:seed:vinhomes": "node --env-file=.env --import tsx scripts/seed-vinhomes-projects.ts",
    "db:seed:commercial": "node --env-file=.env --import tsx scripts/seed-commercial-landings.ts",
    "db:seed:noxh": "node --env-file=.env --import tsx scripts/seed-noxh-long-an.ts",
    "db:verify:landings": "node --env-file=.env --import tsx scripts/verify-landings-db.ts",
    "db:setup": "npm run db:up && npm run db:push && npm run db:seed",
    "db:studio": "prisma studio",
    "media:qc": "node --import tsx scripts/media-image-qc.ts",
    "search:reindex": "node --import tsx scripts/search-reindex.ts",
    "ranking:recompute": "node --import tsx scripts/recompute-ranking.ts",
    "events:dispatch": "node --import tsx scripts/dispatch-events.ts",
    "brand:sync-favicon": "node --import tsx scripts/sync-favicon.ts",
    "brand:sync-clover-icon": "node --import tsx scripts/sync-clover-icon.ts",
    "brand:generate-footer-logo": "node --import tsx scripts/generate-footer-logo.ts",
    "brand:extract-header-paper": "node --import tsx scripts/extract-header-paper.ts",
    "brand:generate-header-logo-mark": "node --import tsx scripts/generate-header-logo-mark.ts",
    "brand:sync-header-assets": "npm run brand:extract-header-paper && npm run brand:generate-header-logo-mark",
    "go-live:secrets": "node --import tsx scripts/generate-secrets.ts",
    "go-live:check-env": "node --import tsx scripts/check-go-live-env.ts",
    "go-live:check-env-files": "node --import tsx scripts/check-env-file-conflict.ts",
    "go-live:smoke": "node --import tsx scripts/smoke-test-site.ts",
    "go-live:smoke-auth": "node --import tsx scripts/smoke-test-auth.ts",
    "go-live:p1-local": "node --import tsx scripts/go-live-p1-local.ts",
    "go-live:p1-vps": "node --import tsx scripts/go-live-p1-vps.ts",
    "go-live:sync-db-url": "node --import tsx scripts/sync-database-url.ts",
    "hero:generate-assets": "node --import tsx scripts/generate-cinematic-hero-assets.ts",
    "hero:enhance-assets": "node --import tsx scripts/enhance-cinematic-hero-assets.ts",
    "hero:import-thu-thiem": "node --import tsx scripts/import-housex-hero-thu-thiem.ts",
    "hero:import-slides": "node --import tsx scripts/import-housex-hero-slides.ts"
  },
  "prisma": {
    "seed": "tsx prisma/seed.ts"
  },
  "dependencies": {
    "@prisma/client": "^6.19.3",
    "@tailwindcss/postcss": "^4",
    "ioredis": "^5.11.1",
    "next": "^16.2.10",
    "react": "19.2.4",
    "react-dom": "19.2.4",
    "sharp": "^0.35.2",
    "tailwindcss": "^4",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "eslint": "^9",
    "eslint-config-next": "16.2.9",
    "prisma": "^6.19.3",
    "tsx": "^4.22.4",
    "typescript": "^5"
  }
}
