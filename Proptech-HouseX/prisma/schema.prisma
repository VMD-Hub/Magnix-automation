generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum ProjectType {
  THUONG_MAI
  NHA_O_XA_HOI
}

enum ProjectStatus {
  SAP_MO_BAN
  DANG_BAN
  DA_BAN_GIAO
  TAM_DUNG
}

enum TransactionType {
  SALE
  RENT
}

enum ListingStatus {
  DRAFT
  PENDING_REVIEW
  ACTIVE
  EXPIRED
  SOLD
  REJECTED
}

enum ListingTier {
  FREE
  VIP
  PREMIUM
}

enum BrokerType {
  FREE
  CTV
  AGENCY
}

/// ADR-009 — Nguồn hàng. Quyết định lớp xác minh tối thiểu + track vận hành.
enum ListingSource {
  DEVELOPER_F1 // sản phẩm sơ cấp từ chủ đầu tư (F1)
  CONSIGNMENT // ký gửi nhà phố/thứ cấp qua Đầu chủ
  BANK_NPL // tài sản phát mãi / xử lý nợ / đấu giá từ ngân hàng
  EXTERNAL_AD // tin đăng quảng cáo từ môi giới ngoài
}

/// ADR-009 — Lớp xác minh tài sản (T0 = chỉ duyệt nội dung → T3 = institutional).
enum VerificationTier {
  T0
  T1
  T2
  T3
}

/// ADR-009 — Đường vận hành/kiếm tiền: quảng cáo (phí gói) vs nội sàn (hoa hồng).
enum MonetizationTrack {
  ADVERTISING
  MANAGED
}

/// ADR-012 — Trạng thái căn trong giỏ hàng dự án sơ cáp (F1).
/// Giữ suất mua (UnitBooking) KHÔNG đổi trạng thái căn — chỉ khi chuyển cọc
/// thủ công (admin) căn mới → DEPOSITED và khóa.
enum ProjectUnitStatus {
  AVAILABLE
  HELD // dự phòng / thao tác nội bộ (không dùng cho giữ suất)
  BOOKED // legacy/demo — ưu tiên đếm UnitBooking thay vì đổi status
  DEPOSITED // đã khóa sau chuyển cọc thủ công
  SOLD
  HANDED_OVER
  LIQUIDATED
}

/// Phase B — Giữ suất mua: nhiều suất/căn khi căn còn AVAILABLE; không lock căn.
enum UnitBookingStatus {
  PENDING
  CONFIRMED
  EXPIRED
  CANCELLED
  CONVERTED_TO_DEPOSIT
}

/// Vai trò tài khoản nền tảng — mọi user đăng ký đều cùng yêu cầu SĐT + email + xác nhận.
enum AccountRole {
  CUSTOMER
  BROKER
}

enum CtvApplicationStatus {
  PENDING
  APPROVED
  REJECTED
}

enum LeadStatus {
  NEW
  CONTACTED
  QUALIFIED
  WON
  LOST
}

enum ConsentSubjectType {
  LEAD
  CUSTOMER
}

enum ConsentAction {
  GRANTED
  DENIED
  WITHDRAWN
  EXPIRED
  SUPERSEDED
}

enum AssignmentStatus {
  ASSIGNED
  ACCEPTED
  RELEASED
  REASSIGNED
}

enum SalesJourney {
  A
  S
  P
}

enum OpportunityStage {
  OPEN
  DISCOVERY
  ACTIVE
  COMMITTED
  WON
  LOST
  CANCELLED
}

enum SalesActivityType {
  CONTACT_ATTEMPT
  CONNECTED
  NOTE
  TASK
  STATE_TRANSITION
  APPOINTMENT_CREATED
  APPOINTMENT_UPDATED
}

enum AppointmentStatus {
  SCHEDULED
  RESCHEDULED
  COMPLETED
  CANCELLED
  NO_SHOW
}

enum BuyerMatchResponse {
  NOT_PRESENTED
  PRESENTED
  INTERESTED
  DECLINED
  NEEDS_REVIEW
}

enum ConversionResult {
  WON
  LOST
}

enum OutcomeReferenceType {
  UNIT_BOOKING
  DEPOSIT
}

enum NurtureEnrollmentStatus {
  ELIGIBLE
  ENROLLED
  SUPPRESSED
  COMPLETED
  CANCELLED
}

enum NurtureDispatchStatus {
  SENT
  FAILED
  SKIPPED
}

/**
 * Phân khúc intent Khách — two lanes Mini App / CRM.
 */
enum LeadSegment {
  NOXH
  CCTM
}

enum AttributionConflictKind {
  CTV_CLAIM_BLOCKED
  OPS_LEAD_CTV_LOCK
}

enum AttributionConflictStatus {
  OPEN
  RESOLVED
  DISMISSED
}

enum AttributionConflictResolution {
  KEEP_PLATFORM
  RELEASE_TO_CTV
  SPLIT_LANE
  DISMISS_BOTH
}

enum ReferralType {
  CTV_PROJECT
  SHARE_LISTING
}

enum CommissionStatus {
  PENDING
  ACCRUED
  PAYABLE
  APPROVED
  PAID
  REJECTED
}

enum ArticleStatus {
  DRAFT
  PUBLISHED
  ARCHIVED
}

enum PromotionCampaignStatus {
  DRAFT
  ACTIVE
  ENDED
}

enum PromotionPrizeTier {
  SPECIAL
  FIRST
  SECOND
  THIRD
  CONSOLATION
  EMPTY
}

enum PromotionPrizeType {
  PHYSICAL
  SERVICE
  VOUCHER
  EMPTY
}

enum PromotionFulfillmentStatus {
  PENDING_CONTRACT
  CONTRACT_SIGNED
  DELIVERED
  EXPIRED
  VOID
}

model Developer {
  id        String   @id @default(uuid())
  name      String
  taxCode   String   @unique @map("tax_code")
  logoUrl   String?  @map("logo_url")
  verified  Boolean  @default(false)
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  projects Project[]

  @@map("developers")
}

model Project {
  id           String        @id @default(uuid())
  developerId  String        @map("developer_id")
  slug         String        @unique
  name         String
  projectType  ProjectType   @map("project_type")
  status       ProjectStatus @default(SAP_MO_BAN)
  province     String
  district     String
  ward         String?
  address      String?
  lat          Float?
  lng          Float?
  totalArea    Float?        @map("total_area")
  density      Float?
  overviewData Json?         @map("overview_data")
  description  String?       @db.Text
  handoverDate DateTime?     @map("handover_date")
  seoTitle     String?       @map("seo_title")
  seoDesc      String?       @map("seo_description")
  deletedAt    DateTime?     @map("deleted_at")
  createdAt    DateTime      @default(now()) @map("created_at")
  updatedAt    DateTime      @updatedAt @map("updated_at")

  developer    Developer         @relation(fields: [developerId], references: [id])
  unitTypes    ProjectUnitType[]
  legalDocs    ProjectLegalDoc[]
  listings     Listing[]
  referrals    Referral[]
  leads        Lead[]
  articles     ArticleProject[]
  units        ProjectUnit[]
  unitBookings UnitBooking[]
  noxhCases    NoxhCase[]

  @@index([province, district])
  @@index([deletedAt])
  @@map("projects")
}

model ProjectUnitType {
  id           String   @id @default(uuid())
  projectId    String   @map("project_id")
  name         String
  areaMin      Float?   @map("area_min")
  areaMax      Float?   @map("area_max")
  bedrooms     Int?
  priceFrom    Decimal? @map("price_from") @db.Decimal(18, 2)
  floorPlanUrl String?  @map("floor_plan_url")
  createdAt    DateTime @default(now()) @map("created_at")

  project  Project       @relation(fields: [projectId], references: [id], onDelete: Cascade)
  listings Listing[]
  units    ProjectUnit[]

  @@map("project_unit_types")
}

/// ADR-012 (Phase A/B) — Giỏ hàng F1. Giữ suất = UnitBooking (không lock).
/// Lock căn chỉ khi admin chuyển cọc → status DEPOSITED + depositBookingId.
model ProjectUnit {
  id               String            @id @default(uuid())
  projectId        String            @map("project_id")
  unitTypeId       String?           @map("unit_type_id")
  code             String // mã căn, vd A-12-05
  block            String? // toà / block / phân khu
  floor            Int?
  direction        String? // hướng (Đông/Tây/...)
  view             String?
  area             Float? // diện tích (m2)
  bedrooms         Int?
  price            Decimal           @db.Decimal(18, 2)
  status           ProjectUnitStatus @default(AVAILABLE)
  /// Cọc thủ công — 1 căn chỉ 1 booking thắng.
  depositBookingId String?           @unique @map("deposit_booking_id")
  depositLockedAt  DateTime?         @map("deposit_locked_at")
  deletedAt        DateTime?         @map("deleted_at")
  createdAt        DateTime          @default(now()) @map("created_at")
  updatedAt        DateTime          @updatedAt @map("updated_at")

  project        Project          @relation(fields: [projectId], references: [id], onDelete: Cascade)
  unitType       ProjectUnitType? @relation(fields: [unitTypeId], references: [id])
  depositBooking UnitBooking?     @relation("DepositBooking", fields: [depositBookingId], references: [id])
  bookings       UnitBooking[]    @relation("UnitBookings")

  @@unique([projectId, code])
  @@index([projectId, status])
  @@index([deletedAt])
  @@map("project_units")
}

/// Giữ suất mua — nhiều bản ghi/căn khi căn AVAILABLE; không khóa tồn kho.
model UnitBooking {
  id              String            @id @default(uuid())
  code            String            @unique
  projectId       String            @map("project_id")
  unitId          String            @map("unit_id")
  customerId      String?           @map("customer_id")
  brokerId        String?           @map("broker_id")
  referralId      String?           @map("referral_id")
  customerName    String            @map("customer_name")
  phone           String
  normalizedPhone String            @map("normalized_phone")
  email           String?
  message         String?           @db.Text
  status          UnitBookingStatus @default(PENDING)
  expiresAt       DateTime?         @map("expires_at")
  convertedAt     DateTime?         @map("converted_at")
  cancelledAt     DateTime?         @map("cancelled_at")
  cancelReason    String?           @map("cancel_reason")
  /// Admin / hệ thống ghi nhận ai chuyển cọc thủ công.
  convertedBy     String?           @map("converted_by")
  createdAt       DateTime          @default(now()) @map("created_at")
  updatedAt       DateTime          @updatedAt @map("updated_at")

  project        Project      @relation(fields: [projectId], references: [id], onDelete: Cascade)
  unit           ProjectUnit  @relation("UnitBookings", fields: [unitId], references: [id], onDelete: Cascade)
  customer       Customer?    @relation(fields: [customerId], references: [id])
  broker         Broker?      @relation(fields: [brokerId], references: [id])
  referral       Referral?    @relation(fields: [referralId], references: [id])
  depositForUnit ProjectUnit? @relation("DepositBooking")
  noxhCase       NoxhCase?

  @@index([unitId, status])
  @@index([projectId, status])
  @@index([normalizedPhone])
  @@map("unit_bookings")
}

model ProjectLegalDoc {
  id         String    @id @default(uuid())
  projectId  String    @map("project_id")
  docType    String    @map("doc_type")
  status     String
  issuedDate DateTime? @map("issued_date")
  fileUrl    String?   @map("file_url")
  createdAt  DateTime  @default(now()) @map("created_at")

  project Project @relation(fields: [projectId], references: [id], onDelete: Cascade)

  @@map("project_legal_docs")
}

model ArticleTag {
  id          String   @id @default(uuid())
  slug        String   @unique
  name        String
  description String?  @db.Text
  createdAt   DateTime @default(now()) @map("created_at")

  articles ArticleTagLink[]

  @@map("article_tags")
}

model Article {
  id            String        @id @default(uuid())
  slug          String        @unique
  title         String
  excerpt       String?       @db.Text
  body          String        @db.Text
  status        ArticleStatus @default(DRAFT)
  publishedAt   DateTime?     @map("published_at")
  coverImageUrl String?       @map("cover_image_url")
  authorName    String?       @map("author_name")
  seoTitle      String?       @map("seo_title")
  seoDesc       String?       @map("seo_description")
  createdAt     DateTime      @default(now()) @map("created_at")
  updatedAt     DateTime      @updatedAt @map("updated_at")

  tags     ArticleTagLink[]
  projects ArticleProject[]

  @@index([status, publishedAt])
  @@map("articles")
}

model ArticleTagLink {
  articleId String @map("article_id")
  tagId     String @map("tag_id")

  article Article    @relation(fields: [articleId], references: [id], onDelete: Cascade)
  tag     ArticleTag @relation(fields: [tagId], references: [id], onDelete: Cascade)

  @@id([articleId, tagId])
  @@map("article_tag_links")
}

model ArticleProject {
  articleId String @map("article_id")
  projectId String @map("project_id")

  article Article @relation(fields: [articleId], references: [id], onDelete: Cascade)
  project Project @relation(fields: [projectId], references: [id], onDelete: Cascade)

  @@id([articleId, projectId])
  @@index([projectId])
  @@map("article_projects")
}

model Broker {
  id              String      @id @default(uuid())
  userAccountId   String      @unique @map("user_account_id")
  fullName        String      @map("full_name")
  phone           String
  licenseNo       String?     @map("license_no")
  licenseVerified Boolean     @default(false) @map("license_verified")
  brokerType      BrokerType  @default(FREE) @map("broker_type")
  /// Mã CTV công khai — chỉ cấp sau khi đơn đăng ký CTV được duyệt.
  ctvCode         String?     @unique @map("ctv_code")
  tier            ListingTier @default(FREE)
  rating          Float?      @default(0)
  createdAt       DateTime    @default(now()) @map("created_at")
  updatedAt       DateTime    @updatedAt @map("updated_at")

  userAccount          UserAccount           @relation(fields: [userAccountId], references: [id])
  listings             Listing[]
  referrals            Referral[]
  assignedLeads        Lead[]                @relation("AssignedBroker")
  commissions          Commission[]
  attributionLocks     AttributionLock[]
  ctvApplication       CtvApplication?
  unitBookings         UnitBooking[]
  noxhCases            NoxhCase[]
  notifications        BrokerNotification[]
  entitlements         AgentEntitlement[]
  quizAttempts         QuizAttempt[]
  attributionConflicts AttributionConflict[]
  leadAssignments      LeadAssignment[]

  @@map("brokers")
}

model Listing {
  id               String            @id @default(uuid())
  code             String            @unique
  brokerId         String            @map("broker_id")
  projectId        String?           @map("project_id")
  unitTypeId       String?           @map("unit_type_id")
  transactionType  TransactionType   @map("transaction_type")
  propertyType     String            @map("property_type")
  price            Decimal           @db.Decimal(18, 2)
  area             Float?
  address          String?
  province         String
  district         String
  ward             String?
  lat              Float?
  lng              Float?
  description      String?           @db.Text
  status           ListingStatus     @default(DRAFT)
  tier             ListingTier       @default(FREE)
  // ADR-009 — phân loại 3 trục (Source × Verification × Track). Mặc định khớp hiện
  // trạng: tin do môi giới đăng = quảng cáo, xác minh T0. Backfill an toàn (additive).
  source           ListingSource     @default(EXTERNAL_AD)
  verificationTier VerificationTier  @default(T0) @map("verification_tier")
  track            MonetizationTrack @default(ADVERTISING)
  verified         Boolean           @default(false) // cờ nhanh; verificationTier là trục chi tiết
  verifiedAt       DateTime?         @map("verified_at")
  expireAt         DateTime?         @map("expire_at")
  rejectReason     String?           @map("reject_reason") @db.Text
  submittedAt      DateTime?         @map("submitted_at")
  reviewedAt       DateTime?         @map("reviewed_at")
  // P2 — precomputed quality & ranking signals (cron/hook cập nhật).
  photoCount       Int               @default(0) @map("photo_count")
  hasVideo         Boolean           @default(false) @map("has_video")
  qualityScore     Int               @default(0) @map("quality_score")
  rankScore        Float             @default(0) @map("rank_score")
  rankUpdatedAt    DateTime?         @map("rank_updated_at")
  // P3 — soft delete (giữ lịch sử/attribution, ẩn khỏi public reads).
  deletedAt        DateTime?         @map("deleted_at")
  createdAt        DateTime          @default(now()) @map("created_at")
  updatedAt        DateTime          @updatedAt @map("updated_at")

  broker      Broker              @relation(fields: [brokerId], references: [id])
  project     Project?            @relation(fields: [projectId], references: [id])
  unitType    ProjectUnitType?    @relation(fields: [unitTypeId], references: [id])
  media       ListingMedia[]
  leads       Lead[]
  referrals   Referral[]
  fingerprint ListingFingerprint?

  @@index([province, district, propertyType, transactionType])
  @@index([status, rankScore])
  @@index([track, status])
  @@index([deletedAt])
  @@map("listings")
}

model ListingMedia {
  id           String   @id @default(uuid())
  listingId    String   @map("listing_id")
  url          String
  type         String   @default("image") // image | video
  position     Int      @default(0)
  provider     String? // bunny | cloudflare_stream | image_cdn
  playbackId   String?  @map("playback_id")
  status       String   @default("READY") // UPLOADING | PROCESSING | READY | REJECTED
  rejectReason String?  @map("reject_reason")
  durationSec  Int?     @map("duration_sec")
  width        Int?
  height       Int?
  phash        String?
  createdAt    DateTime @default(now()) @map("created_at")
  updatedAt    DateTime @updatedAt @map("updated_at")

  listing Listing @relation(fields: [listingId], references: [id], onDelete: Cascade)

  @@index([listingId, status])
  @@map("listing_media")
}

enum AuthTokenType {
  EMAIL_VERIFY
  PASSWORD_RESET
}

enum OpsToolCode {
  TELESALES_CRM
}

enum OpsToolGrantStatus {
  ACTIVE
  REVOKED
}

/// Tài khoản đăng nhập thống nhất — khách hàng (CUSTOMER) hoặc môi giới đăng tin (BROKER).
model UserAccount {
  id              String      @id @default(uuid())
  role            AccountRole
  name            String
  phone           String
  normalizedPhone String      @unique @map("normalized_phone")
  email           String      @unique
  emailVerified   Boolean     @default(false) @map("email_verified")
  emailVerifiedAt DateTime?   @map("email_verified_at")
  marketingOptIn  Boolean     @default(true) @map("marketing_opt_in")
  passwordHash    String      @map("password_hash")
  /// Zalo user id (Mini App / OA) — ADR-014
  zaloUserId      String?     @unique @map("zalo_user_id")
  createdAt       DateTime    @default(now()) @map("created_at")
  updatedAt       DateTime    @updatedAt @map("updated_at")

  customer       Customer?
  broker         Broker?
  authTokens     UserAuthToken[]
  opsToolGrants  OpsToolGrant[]

  @@index([role])
  @@map("user_accounts")
}

/// Super Admin cấp quyền tool Ops trên Mini App / web telesales (không dùng AgentEntitlement CTV).
model OpsToolGrant {
  id            String             @id @default(uuid())
  userAccountId String             @map("user_account_id")
  tool          OpsToolCode        @default(TELESALES_CRM)
  status        OpsToolGrantStatus @default(ACTIVE)
  grantedBy     String             @map("granted_by")
  note          String?
  grantedAt     DateTime           @default(now()) @map("granted_at")
  revokedAt     DateTime?          @map("revoked_at")
  createdAt     DateTime           @default(now()) @map("created_at")
  updatedAt     DateTime           @updatedAt @map("updated_at")

  userAccount UserAccount @relation(fields: [userAccountId], references: [id], onDelete: Cascade)

  @@unique([userAccountId, tool])
  @@index([status, tool])
  @@map("ops_tool_grants")
}

model Customer {
  id              String   @id @default(uuid())
  userAccountId   String?  @unique @map("user_account_id")
  name            String
  phone           String
  normalizedPhone String   @unique @map("normalized_phone")
  email           String?
  createdAt       DateTime @default(now()) @map("created_at")
  updatedAt       DateTime @updatedAt @map("updated_at")

  userAccount           UserAccount?           @relation(fields: [userAccountId], references: [id])
  leads                 Lead[]
  attributionLock       AttributionLock?
  unitBookings          UnitBooking[]
  promotionParticipants PromotionParticipant[]
  promotionSpins        PromotionSpin[]
  promotionWins         PromotionWin[]
  attributionConflicts  AttributionConflict[]
  consentRecords        ConsentRecord[]

  @@map("customers")
}

/// Token một lần: xác nhận email, đặt lại mật khẩu (chỉ lưu hash).
model UserAuthToken {
  id            String        @id @default(uuid())
  userAccountId String        @map("user_account_id")
  type          AuthTokenType
  tokenHash     String        @unique @map("token_hash")
  expiresAt     DateTime      @map("expires_at")
  usedAt        DateTime?     @map("used_at")
  createdAt     DateTime      @default(now()) @map("created_at")

  userAccount UserAccount @relation(fields: [userAccountId], references: [id], onDelete: Cascade)

  @@index([userAccountId, type])
  @@map("user_auth_tokens")
}

/// Đơn đăng ký CTV — môi giới đã có tài khoản đăng tin, chờ admin duyệt.
/// Vận hành: duyệt chỉ khi hoàn thành khóa đào tạo hội nhập (LMS — phase sau).
model CtvApplication {
  id           String               @id @default(uuid())
  brokerId     String               @unique @map("broker_id")
  idNumber     String?              @map("id_number")
  experience   String?              @db.Text
  region       String?
  motivation   String?              @db.Text
  status       CtvApplicationStatus @default(PENDING)
  rejectReason String?              @map("reject_reason")
  reviewedAt   DateTime?            @map("reviewed_at")
  createdAt    DateTime             @default(now()) @map("created_at")
  updatedAt    DateTime             @updatedAt @map("updated_at")

  broker Broker @relation(fields: [brokerId], references: [id], onDelete: Cascade)

  @@index([status])
  @@map("ctv_applications")
}

model Lead {
  id               String       @id @default(uuid())
  customerId       String?      @map("customer_id")
  listingId        String?      @map("listing_id")
  projectId        String?      @map("project_id")
  referralId       String?      @map("referral_id")
  assignedBrokerId String?      @map("assigned_broker_id")
  source           String       @default("organic")
  sourceMeta       Json?        @map("source_meta")
  /// CRM-R4 — kênh liên hệ nurture + script gợi ý (channels, nurtureScriptId, opsNote).
  opsMeta          Json         @default("{}") @map("ops_meta")
  segment          LeadSegment? @map("segment")
  message          String?      @db.Text
  status           LeadStatus   @default(NEW)
  createdAt        DateTime     @default(now()) @map("created_at")
  updatedAt        DateTime     @updatedAt @map("updated_at")

  customer              Customer?              @relation(fields: [customerId], references: [id])
  listing               Listing?               @relation(fields: [listingId], references: [id])
  project               Project?               @relation(fields: [projectId], references: [id])
  referral              Referral?              @relation(fields: [referralId], references: [id])
  assignedBroker        Broker?                @relation("AssignedBroker", fields: [assignedBrokerId], references: [id])
  commission            Commission?
  noxhCases             NoxhCase[]
  attributionConflicts  AttributionConflict[]
  inboundUidTouch       InboundUidLead?
  consentRecords        ConsentRecord[]
  assignments           LeadAssignment[]
  buyerProfile          BuyerProfile?
  buyerProfileMutations BuyerProfileMutation[]
  buyerMatches          BuyerMatch[]
  opportunities         Opportunity[]
  proposalSnapshots     ProposalSnapshot[]
  conversionOutcomes    ConversionOutcome[]
  nurtureEnrollments    NurtureEnrollment[]
  salesActivities       SalesActivity[]
  appointments          Appointment[]

  @@index([status])
  @@index([assignedBrokerId, status])
  @@index([segment])
  @@map("leads")
}

/// ADR-015 G1 — authoritative append-only consent ledger.
model ConsentRecord {
  id             String             @id @default(uuid())
  subjectType    ConsentSubjectType @map("subject_type")
  subjectId      String             @map("subject_id")
  leadId         String?            @map("lead_id")
  customerId     String?            @map("customer_id")
  purpose        String
  channel        String
  action         ConsentAction
  proofType      String             @map("proof_type")
  proofRef       String?            @map("proof_ref")
  proofMetadata  Json               @default("{}") @map("proof_metadata")
  policyVersion  String             @map("policy_version")
  actorId        String             @map("actor_id")
  source         String
  occurredAt     DateTime           @map("occurred_at")
  correlationId  String             @map("correlation_id")
  idempotencyKey String             @unique @map("idempotency_key")
  createdAt      DateTime           @default(now()) @map("created_at")

  lead     Lead?     @relation(fields: [leadId], references: [id], onDelete: Restrict)
  customer Customer? @relation(fields: [customerId], references: [id], onDelete: Restrict)

  @@index([subjectType, subjectId, purpose, channel, occurredAt(sort: Desc)])
  @@index([leadId])
  @@index([customerId])
  @@map("consent_records")
}

/// One row per assignment period; reassignment closes the prior row instead of
/// overwriting its owner/audit facts.
model LeadAssignment {
  id                           String           @id @default(uuid())
  leadId                       String           @map("lead_id")
  ownerId                      String           @map("owner_id")
  status                       AssignmentStatus @default(ASSIGNED)
  reason                       String?
  assignedBy                   String           @map("assigned_by")
  assignedAt                   DateTime         @default(now()) @map("assigned_at")
  acceptedAt                   DateTime?        @map("accepted_at")
  firstAttemptAt               DateTime?        @map("first_attempt_at")
  firstConnectedAt             DateTime?        @map("first_connected_at")
  acceptanceSlaDueAt           DateTime?        @map("acceptance_sla_due_at")
  firstResponseSlaDueAt        DateTime?        @map("first_response_sla_due_at")
  closedAt                     DateTime?        @map("closed_at")
  correlationId                String           @map("correlation_id")
  idempotencyKey               String           @unique @map("idempotency_key")
  acceptedIdempotencyKey       String?          @unique @map("accepted_idempotency_key")
  acceptedCorrelationId        String?          @map("accepted_correlation_id")
  firstAttemptIdempotencyKey   String?          @unique @map("first_attempt_idempotency_key")
  firstAttemptCorrelationId    String?          @map("first_attempt_correlation_id")
  firstConnectedIdempotencyKey String?          @unique @map("first_connected_idempotency_key")
  firstConnectedCorrelationId  String?          @map("first_connected_correlation_id")
  createdAt                    DateTime         @default(now()) @map("created_at")
  updatedAt                    DateTime         @updatedAt @map("updated_at")

  lead  Lead                 @relation(fields: [leadId], references: [id], onDelete: Cascade)
  owner Broker               @relation(fields: [ownerId], references: [id])
  facts LeadAssignmentFact[]

  @@index([leadId, status])
  @@index([ownerId, status])
  @@index([acceptanceSlaDueAt])
  @@index([firstResponseSlaDueAt])
  @@map("lead_assignments")
}

/// Immutable command ledger gives assignment facts one global idempotency
/// namespace and binds retries to their complete audit input.
model LeadAssignmentFact {
  id             String   @id @default(uuid())
  assignmentId   String   @map("assignment_id")
  fact           String
  actorId        String   @map("actor_id")
  occurredAt     DateTime @map("occurred_at")
  correlationId  String   @map("correlation_id")
  idempotencyKey String   @unique @map("idempotency_key")
  createdAt      DateTime @default(now()) @map("created_at")

  assignment LeadAssignment @relation(fields: [assignmentId], references: [id], onDelete: Cascade)

  @@index([assignmentId, occurredAt])
  @@map("lead_assignment_facts")
}

/// Minimum necessary buyer-needs projection. Financial details never enter events.
model BuyerProfile {
  id                String   @id @default(uuid())
  leadId            String   @unique @map("lead_id")
  budgetMin         Decimal? @map("budget_min") @db.Decimal(18, 2)
  budgetMax         Decimal? @map("budget_max") @db.Decimal(18, 2)
  availableCash     Decimal? @map("available_cash") @db.Decimal(18, 2)
  paymentPreference String?  @map("payment_preference")
  locations         String[] @default([])
  propertyTypes     String[] @default([]) @map("property_types")
  bedroomsMin       Int?     @map("bedrooms_min")
  purchasePurpose   String?  @map("purchase_purpose")
  timeframe         String?
  readiness         String?
  mustHaves         String[] @default([]) @map("must_haves")
  completeness      Int      @default(0)
  version           Int      @default(1)
  updatedBy         String   @map("updated_by")
  correlationId     String   @map("correlation_id")
  idempotencyKey    String   @unique @map("idempotency_key")
  createdAt         DateTime @default(now()) @map("created_at")
  updatedAt         DateTime @updatedAt @map("updated_at")

  lead      Lead                   @relation(fields: [leadId], references: [id], onDelete: Cascade)
  matches   BuyerMatch[]
  mutations BuyerProfileMutation[]

  @@map("buyer_profiles")
}

/// Immutable command ledger prevents an older idempotency key from replaying
/// stale buyer-profile data after the mutable projection has advanced.
model BuyerProfileMutation {
  id             String   @id @default(uuid())
  buyerProfileId String   @map("buyer_profile_id")
  leadId         String   @map("lead_id")
  idempotencyKey String   @unique @map("idempotency_key")
  inputHash      String   @map("input_hash")
  resultVersion  Int      @map("result_version")
  createdAt      DateTime @default(now()) @map("created_at")

  buyerProfile BuyerProfile @relation(fields: [buyerProfileId], references: [id], onDelete: Cascade)
  lead         Lead         @relation(fields: [leadId], references: [id], onDelete: Cascade)

  @@index([buyerProfileId])
  @@index([leadId, createdAt])
  @@map("buyer_profile_mutations")
}

/// ADR-015 SC-2 — append-only, explainable recommendation snapshot. It does not
/// reserve inventory, assert legal eligibility, or mutate opportunity stage.
model BuyerMatch {
  id                 String             @id @default(uuid())
  leadId             String             @map("lead_id")
  buyerProfileId     String             @map("buyer_profile_id")
  opportunityId      String?            @map("opportunity_id")
  projectRef         String?            @map("project_ref")
  listingRef         String?            @map("listing_ref")
  unitRef            String?            @map("unit_ref")
  score              Int
  scoreBreakdown     Json               @map("score_breakdown")
  reasons            String[]           @default([])
  blockers           String[]           @default([])
  rulesVersion       String             @map("rules_version")
  inventoryCheckedAt DateTime?          @map("inventory_checked_at")
  presentedAt        DateTime?          @map("presented_at")
  response           BuyerMatchResponse @default(NOT_PRESENTED)
  actorId            String             @map("actor_id")
  correlationId      String             @map("correlation_id")
  idempotencyKey     String             @unique @map("idempotency_key")
  createdAt          DateTime           @default(now()) @map("created_at")

  lead         Lead         @relation(fields: [leadId], references: [id], onDelete: Cascade)
  buyerProfile BuyerProfile @relation(fields: [buyerProfileId], references: [id], onDelete: Cascade)
  opportunity  Opportunity? @relation(fields: [opportunityId], references: [id], onDelete: SetNull)
  proposals    ProposalSnapshot[]

  @@index([leadId, createdAt(sort: Desc)])
  @@index([buyerProfileId, createdAt(sort: Desc)])
  @@index([opportunityId])
  @@map("buyer_matches")
}

model Opportunity {
  id             String           @id @default(uuid())
  leadId         String           @map("lead_id")
  journey        SalesJourney
  stage          OpportunityStage @default(OPEN)
  projectRef     String?          @map("project_ref")
  listingRef     String?          @map("listing_ref")
  unitRef        String?          @map("unit_ref")
  reason         String?
  actorId        String           @map("actor_id")
  correlationId  String           @map("correlation_id")
  idempotencyKey String           @unique @map("idempotency_key")
  createdAt      DateTime         @default(now()) @map("created_at")
  updatedAt      DateTime         @updatedAt @map("updated_at")

  lead               Lead                @relation(fields: [leadId], references: [id], onDelete: Cascade)
  activities         SalesActivity[]
  appointments       Appointment[]
  buyerMatches       BuyerMatch[]
  proposalSnapshots  ProposalSnapshot[]
  conversionOutcome  ConversionOutcome?

  @@index([leadId, stage])
  @@index([journey, stage])
  @@map("opportunities")
}

/// ADR-015 SC-4 — immutable Journey P inventory/proposal snapshot. Append-only.
model ProposalSnapshot {
  id                         String       @id @default(uuid())
  opportunityId              String       @map("opportunity_id")
  leadId                     String       @map("lead_id")
  journey                    SalesJourney
  projectRef                 String       @map("project_ref")
  unitRef                    String       @map("unit_ref")
  buyerMatchId               String?      @map("buyer_match_id")
  unitCode                   String       @map("unit_code")
  unitStatus                 String       @map("unit_status")
  price                      Decimal      @db.Decimal(18, 2)
  currency                   String       @default("VND")
  depositBookingIdAtSnapshot String?      @map("deposit_booking_id_at_snapshot")
  termsVersion               String       @map("terms_version")
  inventoryCheckedAt         DateTime     @map("inventory_checked_at")
  generatedAt                DateTime     @map("generated_at")
  actorId                    String       @map("actor_id")
  correlationId              String       @map("correlation_id")
  idempotencyKey             String       @unique @map("idempotency_key")
  createdAt                  DateTime     @default(now()) @map("created_at")

  opportunity Opportunity @relation(fields: [opportunityId], references: [id], onDelete: Cascade)
  lead        Lead        @relation(fields: [leadId], references: [id], onDelete: Cascade)
  buyerMatch  BuyerMatch? @relation(fields: [buyerMatchId], references: [id], onDelete: SetNull)

  @@index([opportunityId, createdAt(sort: Desc)])
  @@index([leadId, createdAt(sort: Desc)])
  @@map("proposal_snapshots")
}

/// ADR-015 SC-5 — terminal conversion outcome referencing journey authority.
model ConversionOutcome {
  id             String               @id @default(uuid())
  opportunityId  String               @unique @map("opportunity_id")
  leadId         String               @map("lead_id")
  journey        SalesJourney
  result         ConversionResult
  reasonCode     String               @map("reason_code")
  reasonDetail   String?              @map("reason_detail") @db.Text
  referenceType  OutcomeReferenceType @map("reference_type")
  referenceId    String               @map("reference_id")
  value          Decimal?             @db.Decimal(18, 2)
  currency       String?
  referralId     String?              @map("referral_id")
  brokerId       String?              @map("broker_id")
  actorId        String               @map("actor_id")
  correlationId  String               @map("correlation_id")
  idempotencyKey String               @unique @map("idempotency_key")
  occurredAt     DateTime             @map("occurred_at")
  createdAt      DateTime             @default(now()) @map("created_at")

  opportunity Opportunity @relation(fields: [opportunityId], references: [id], onDelete: Cascade)
  lead        Lead        @relation(fields: [leadId], references: [id], onDelete: Cascade)

  @@index([leadId, occurredAt(sort: Desc)])
  @@index([journey, result])
  @@map("conversion_outcomes")
}

/// ADR-015 SC-6 — consent-safe nurture enrollment (subject = leadId only).
model NurtureEnrollment {
  id             String                  @id @default(uuid())
  leadId         String                  @map("lead_id")
  opportunityId  String?                 @map("opportunity_id")
  purpose        String
  channel        String
  status         NurtureEnrollmentStatus @default(ENROLLED)
  scriptId       String?                 @map("script_id")
  cohortKey      String?                 @map("cohort_key")
  actorId        String                  @map("actor_id")
  correlationId  String                  @map("correlation_id")
  idempotencyKey String                  @unique @map("idempotency_key")
  createdAt      DateTime                @default(now()) @map("created_at")
  updatedAt      DateTime                @updatedAt @map("updated_at")

  lead      Lead              @relation(fields: [leadId], references: [id], onDelete: Cascade)
  dispatches NurtureDispatch[]

  @@index([leadId, purpose, channel])
  @@index([status, updatedAt])
  @@map("nurture_enrollments")
}

model NurtureDispatch {
  id             String                @id @default(uuid())
  enrollmentId   String                @map("enrollment_id")
  status         NurtureDispatchStatus
  actorId        String                @map("actor_id")
  occurredAt     DateTime              @map("occurred_at")
  correlationId  String                @map("correlation_id")
  idempotencyKey String                @unique @map("idempotency_key")
  createdAt      DateTime              @default(now()) @map("created_at")

  enrollment NurtureEnrollment @relation(fields: [enrollmentId], references: [id], onDelete: Cascade)

  @@index([enrollmentId, occurredAt(sort: Desc)])
  @@map("nurture_dispatches")
}

/// Append-only sales timeline. Notes remain protected and are excluded from events.
model SalesActivity {
  id             String            @id @default(uuid())
  leadId         String            @map("lead_id")
  opportunityId  String?           @map("opportunity_id")
  type           SalesActivityType
  channel        String?
  note           String?           @db.Text
  fromState      String?           @map("from_state")
  toState        String?           @map("to_state")
  reason         String?
  actorId        String            @map("actor_id")
  occurredAt     DateTime          @map("occurred_at")
  dueAt          DateTime?         @map("due_at")
  correlationId  String            @map("correlation_id")
  idempotencyKey String            @unique @map("idempotency_key")
  metadata       Json              @default("{}")
  createdAt      DateTime          @default(now()) @map("created_at")

  lead        Lead         @relation(fields: [leadId], references: [id], onDelete: Cascade)
  opportunity Opportunity? @relation(fields: [opportunityId], references: [id], onDelete: SetNull)

  @@index([leadId, occurredAt(sort: Desc)])
  @@index([opportunityId, occurredAt(sort: Desc)])
  @@map("sales_activities")
}

model Appointment {
  id             String            @id @default(uuid())
  leadId         String            @map("lead_id")
  opportunityId  String?           @map("opportunity_id")
  status         AppointmentStatus @default(SCHEDULED)
  channel        String
  scheduledAt    DateTime          @map("scheduled_at")
  durationMin    Int?              @map("duration_min")
  attendedAt     DateTime?         @map("attended_at")
  noShowAt       DateTime?         @map("no_show_at")
  cancelledAt    DateTime?         @map("cancelled_at")
  nextAction     String?           @map("next_action")
  actorId        String            @map("actor_id")
  correlationId  String            @map("correlation_id")
  idempotencyKey String            @unique @map("idempotency_key")
  createdAt      DateTime          @default(now()) @map("created_at")
  updatedAt      DateTime          @updatedAt @map("updated_at")

  lead        Lead         @relation(fields: [leadId], references: [id], onDelete: Cascade)
  opportunity Opportunity? @relation(fields: [opportunityId], references: [id], onDelete: SetNull)

  @@index([leadId, scheduledAt])
  @@index([status, scheduledAt])
  @@map("appointments")
}

model Referral {
  id         String       @id @default(uuid())
  brokerId   String       @map("broker_id")
  projectId  String?      @map("project_id")
  listingId  String?      @map("listing_id")
  code       String       @unique
  type       ReferralType
  clickCount Int          @default(0) @map("click_count")
  expiresAt  DateTime?    @map("expires_at")
  createdAt  DateTime     @default(now()) @map("created_at")

  broker       Broker        @relation(fields: [brokerId], references: [id])
  project      Project?      @relation(fields: [projectId], references: [id])
  listing      Listing?      @relation(fields: [listingId], references: [id])
  leads        Lead[]
  commissions  Commission[]
  unitBookings UnitBooking[]

  @@map("referrals")
}

model Commission {
  id              String           @id @default(uuid())
  leadId          String           @unique @map("lead_id")
  referralId      String?          @map("referral_id")
  brokerId        String           @map("broker_id")
  amount          Decimal          @db.Decimal(18, 2)
  rate            Float?
  status          CommissionStatus @default(PENDING)
  /// NOXH pipeline — thời điểm ký HĐMB (ghi nhận ACCRUED).
  signedAt        DateTime?        @map("signed_at")
  accruedAt       DateTime?        @map("accrued_at")
  payableAt       DateTime?        @map("payable_at")
  expectedPayDate DateTime?        @map("expected_pay_date") @db.Date
  paidAt          DateTime?        @map("paid_at")
  createdAt       DateTime         @default(now()) @map("created_at")

  lead     Lead      @relation(fields: [leadId], references: [id])
  referral Referral? @relation(fields: [referralId], references: [id])
  broker   Broker    @relation(fields: [brokerId], references: [id])

  @@index([brokerId, status])
  @@index([status, expectedPayDate])
  @@map("commissions")
}

// P1 — Canonical property: gom nhiều tin đăng của cùng 1 BĐS (nhiều broker rao)
// về một thực thể gốc, tránh loãng SEO + UX rác.
model CanonicalProperty {
  id           String   @id @default(uuid())
  clusterKey   String   @unique @map("cluster_key")
  projectId    String?  @map("project_id")
  unitTypeId   String?  @map("unit_type_id")
  propertyType String   @map("property_type")
  province     String
  district     String
  offerCount   Int      @default(0) @map("offer_count")
  createdAt    DateTime @default(now()) @map("created_at")
  updatedAt    DateTime @updatedAt @map("updated_at")

  fingerprints ListingFingerprint[]

  @@map("canonical_properties")
}

// P1 — Fingerprint mỗi listing để chống trùng (hard dupe + near dupe).
model ListingFingerprint {
  id          String   @id @default(uuid())
  listingId   String   @unique @map("listing_id")
  contentHash String   @map("content_hash") // SimHash hex 64-bit của mô tả chuẩn hoá
  dupeKey     String   @map("dupe_key") // hard-dupe key (cùng broker + cùng BĐS)
  imagePhash  String[] @map("image_phash")
  canonicalId String?  @map("canonical_id")
  createdAt   DateTime @default(now()) @map("created_at")

  listing   Listing            @relation(fields: [listingId], references: [id], onDelete: Cascade)
  canonical CanonicalProperty? @relation(fields: [canonicalId], references: [id])

  @@index([dupeKey])
  @@index([canonicalId])
  @@map("listing_fingerprints")
}

// P0 — Attribution lock: 1 khách chỉ thuộc 1 broker trong cửa sổ hiệu lực.
model AttributionLock {
  id         String   @id @default(uuid())
  customerId String   @unique @map("customer_id")
  brokerId   String   @map("broker_id")
  referralId String?  @map("referral_id")
  source     String   @default("referral") // referral | first_lead | manual
  lockedAt   DateTime @default(now()) @map("locked_at")
  expiresAt  DateTime @map("expires_at")

  customer Customer @relation(fields: [customerId], references: [id])
  broker   Broker   @relation(fields: [brokerId], references: [id])

  @@index([brokerId])
  @@index([expiresAt])
  @@map("attribution_locks")
}

// P3 — Lịch sử chuyển trạng thái (audit) cho listing/lead/project. Generic để
// một bảng phục vụ nhiều entity; truy vết "ai đổi gì, khi nào, vì sao".
model StatusHistory {
  id         String   @id @default(uuid())
  entity     String // listing | lead | project
  entityId   String   @map("entity_id")
  fromStatus String?  @map("from_status")
  toStatus   String   @map("to_status")
  reason     String?
  actor      String? // brokerId / userId / system
  createdAt  DateTime @default(now()) @map("created_at")

  @@index([entity, entityId])
  @@map("status_history")
}

enum OutboxStatus {
  PENDING
  PROCESSING
  DONE
  DEAD
}

// P2 — Transactional outbox: ghi sự kiện CÙNG transaction với thay đổi domain,
// dispatcher xử lý side-effect (notify n8n…) bất đồng bộ → tách khỏi request,
// at-least-once + retry/backoff + dead-letter.
model OutboxEvent {
  id            String       @id @default(uuid())
  type          String // lead.won | commission.created | ...
  payload       Json
  dedupeKey     String?      @unique @map("dedupe_key")
  aggregateType String?      @map("aggregate_type")
  aggregateId   String?      @map("aggregate_id")
  correlationId String?      @map("correlation_id")
  schemaVersion Int          @default(1) @map("schema_version")
  occurredAt    DateTime     @default(now()) @map("occurred_at")
  status        OutboxStatus @default(PENDING)
  attempts      Int          @default(0)
  maxAttempts   Int          @default(8) @map("max_attempts")
  availableAt   DateTime     @default(now()) @map("available_at")
  lockedAt      DateTime?    @map("locked_at")
  lastError     String?      @map("last_error") @db.Text
  createdAt     DateTime     @default(now()) @map("created_at")
  processedAt   DateTime?    @map("processed_at")

  @@index([status, availableAt])
  @@index([aggregateType, aggregateId])
  @@map("outbox_events")
}

// P0 — Audit mọi lần gán/tranh chấp quyền sở hữu khách (chống "lộn cò").
model AttributionEvent {
  id         String   @id @default(uuid())
  customerId String   @map("customer_id")
  fromBroker String?  @map("from_broker")
  toBroker   String?  @map("to_broker")
  referralId String?  @map("referral_id")
  reason     String // first_touch | conflict_kept | expired_reassign | self_referral_blocked
  createdAt  DateTime @default(now()) @map("created_at")

  @@index([customerId])
  @@map("attribution_events")
}

/// CRM-R2 — hàng đợi xung đột Ops vs CTV (SĐT trùng).
model AttributionConflict {
  id              String                         @id @default(uuid())
  normalizedPhone String                         @map("normalized_phone")
  kind            AttributionConflictKind
  status          AttributionConflictStatus      @default(OPEN)
  rejectReason    String?                        @map("reject_reason")
  customerId      String?                        @map("customer_id")
  platformLeadId  String?                        @map("platform_lead_id")
  noxhCaseId      String?                        @map("noxh_case_id")
  brokerId        String?                        @map("broker_id")
  resolution      AttributionConflictResolution?
  resolutionNote  String?                        @map("resolution_note") @db.Text
  resolvedBy      String?                        @map("resolved_by")
  resolvedAt      DateTime?                      @map("resolved_at")
  meta            Json                           @default("{}")
  createdAt       DateTime                       @default(now()) @map("created_at")
  updatedAt       DateTime                       @updatedAt @map("updated_at")

  customer     Customer? @relation(fields: [customerId], references: [id])
  platformLead Lead?     @relation(fields: [platformLeadId], references: [id])
  noxhCase     NoxhCase? @relation(fields: [noxhCaseId], references: [id])
  broker       Broker?   @relation(fields: [brokerId], references: [id])

  @@index([status, createdAt(sort: Desc)])
  @@index([normalizedPhone, status])
  @@map("attribution_conflicts")
}

/// Lucky wheel — chương trình khuyến mãi (1 campaign Phase 1).
model PromotionCampaign {
  id                 String                  @id @default(uuid())
  slug               String                  @unique
  name               String
  description        String?                 @db.Text
  termsMarkdown      String?                 @map("terms_markdown") @db.Text
  status             PromotionCampaignStatus @default(DRAFT)
  startAt            DateTime                @map("start_at")
  endAt              DateTime                @map("end_at")
  maxSpinsPerAccount Int                     @default(6) @map("max_spins_per_account")
  maxSpinsPerDay     Int                     @default(3) @map("max_spins_per_day")
  spinDurationMs     Int                     @default(8000) @map("spin_duration_ms")
  /// Mảng 12 prizeId — layout ô trên vòng quay.
  wheelLayout        Json                    @map("wheel_layout")
  createdAt          DateTime                @default(now()) @map("created_at")
  updatedAt          DateTime                @updatedAt @map("updated_at")

  prizes       PromotionPrize[]
  participants PromotionParticipant[]
  spins        PromotionSpin[]
  wins         PromotionWin[]

  @@index([status, startAt, endAt])
  @@map("promotion_campaigns")
}

model PromotionPrize {
  id            String             @id @default(uuid())
  campaignId    String             @map("campaign_id")
  tier          PromotionPrizeTier
  prizeType     PromotionPrizeType @map("prize_type")
  label         String
  shortLabel    String             @map("short_label")
  description   String?            @db.Text
  imageUrl      String?            @map("image_url")
  weightPercent Float              @map("weight_percent")
  totalQty      Int                @map("total_qty")
  remainingQty  Int                @map("remaining_qty")
  activeFrom    DateTime?          @map("active_from")
  activeUntil   DateTime?          @map("active_until")
  sortOrder     Int                @default(0) @map("sort_order")
  createdAt     DateTime           @default(now()) @map("created_at")
  updatedAt     DateTime           @updatedAt @map("updated_at")

  campaign PromotionCampaign @relation(fields: [campaignId], references: [id], onDelete: Cascade)
  spins    PromotionSpin[]
  wins     PromotionWin[]

  @@index([campaignId])
  @@map("promotion_prizes")
}

model PromotionParticipant {
  id                String    @id @default(uuid())
  campaignId        String    @map("campaign_id")
  customerId        String    @map("customer_id")
  userAccountId     String    @map("user_account_id")
  noxhEligibleAt    DateTime? @map("noxh_eligible_at")
  shareBonusGranted Boolean   @default(false) @map("share_bonus_granted")
  createdAt         DateTime  @default(now()) @map("created_at")
  updatedAt         DateTime  @updatedAt @map("updated_at")

  campaign PromotionCampaign @relation(fields: [campaignId], references: [id], onDelete: Cascade)
  customer Customer          @relation(fields: [customerId], references: [id], onDelete: Cascade)
  spins    PromotionSpin[]
  win      PromotionWin?

  @@unique([campaignId, customerId])
  @@index([userAccountId])
  @@map("promotion_participants")
}

model PromotionSpin {
  id            String   @id @default(uuid())
  campaignId    String   @map("campaign_id")
  customerId    String   @map("customer_id")
  participantId String   @map("participant_id")
  prizeId       String?  @map("prize_id")
  segmentIndex  Int      @map("segment_index")
  isPreview     Boolean  @default(false) @map("is_preview")
  ipHash        String?  @map("ip_hash")
  createdAt     DateTime @default(now()) @map("created_at")

  campaign    PromotionCampaign    @relation(fields: [campaignId], references: [id], onDelete: Cascade)
  customer    Customer             @relation(fields: [customerId], references: [id], onDelete: Cascade)
  participant PromotionParticipant @relation(fields: [participantId], references: [id], onDelete: Cascade)
  prize       PromotionPrize?      @relation(fields: [prizeId], references: [id])
  win         PromotionWin?

  @@index([campaignId, customerId, createdAt])
  @@index([createdAt])
  @@map("promotion_spins")
}

model PromotionWin {
  id                String                     @id @default(uuid())
  campaignId        String                     @map("campaign_id")
  customerId        String                     @map("customer_id")
  participantId     String                     @unique @map("participant_id")
  prizeId           String                     @map("prize_id")
  spinId            String                     @unique @map("spin_id")
  redemptionCode    String                     @unique @map("redemption_code")
  fulfillmentStatus PromotionFulfillmentStatus @default(PENDING_CONTRACT) @map("fulfillment_status")
  displayName       String                     @map("display_name")
  fulfilledAt       DateTime?                  @map("fulfilled_at")
  createdAt         DateTime                   @default(now()) @map("created_at")
  updatedAt         DateTime                   @updatedAt @map("updated_at")

  campaign    PromotionCampaign    @relation(fields: [campaignId], references: [id], onDelete: Cascade)
  customer    Customer             @relation(fields: [customerId], references: [id], onDelete: Cascade)
  participant PromotionParticipant @relation(fields: [participantId], references: [id], onDelete: Cascade)
  prize       PromotionPrize       @relation(fields: [prizeId], references: [id])
  spin        PromotionSpin        @relation(fields: [spinId], references: [id])

  @@unique([campaignId, customerId])
  @@index([campaignId, createdAt])
  @@map("promotion_wins")
}

// --- Phase 0: NOXH Case pipeline (CTV + Ops) — ADR-013 Postgres SoR ---

enum NoxhMilestone {
  M1_RECEIVED
  M2_DOCUMENTS
  M3_SUBMITTED
  M4_APPROVED
  M5_SIGNED
}

enum NoxhCaseStatus {
  ACTIVE
  UNREACHABLE
  DECLINED
  COMPLETED
  RELEASED
}

enum NoxhDocType {
  DOC_ID
  DOC_MARRIAGE
  DOC_RESIDENCE
  DOC_OBJECT
  DOC_HOUSING
  DOC_INCOME
  DOC_APPLICATION
  DOC_DEPOSIT_PROOF
  DOC_CIC
  DOC_BANK_INCOME
  DOC_LOAN_APP
}

enum NoxhDocStatus {
  NOT_REQUIRED
  MISSING
  RECEIVED
  REVIEWING
  PASSED
  REJECTED
  EXPIRED
}

enum CtvAssistType {
  NUDGE
  ESCORT
  NOTE
}

/// Hồ sơ NOXH — 1 khách (SĐT) trong một chu kỳ xử lý; CTV theo dõi qua portal.
model NoxhCase {
  id                  String         @id @default(uuid())
  code                String         @unique
  customerName        String         @map("customer_name")
  phone               String
  normalizedPhone     String         @map("normalized_phone")
  brokerId            String?        @map("broker_id")
  leadId              String?        @unique @map("lead_id")
  projectId           String?        @map("project_id")
  unitBookingId       String?        @unique @map("unit_booking_id")
  objectGroup         String         @default("WORKER") @map("object_group")
  intendToBorrow      Boolean        @default(false) @map("intend_to_borrow")
  milestone           NoxhMilestone  @default(M1_RECEIVED)
  milestoneSub        String?        @map("milestone_sub")
  caseStatus          NoxhCaseStatus @default(ACTIVE) @map("case_status")
  opsNote             String?        @map("ops_note") @db.Text
  attributionLockedAt DateTime?      @map("attribution_locked_at")
  consultScheduledAt  DateTime?      @map("consult_scheduled_at")
  lockExpiresAt       DateTime?      @map("lock_expires_at")
  claimedAt           DateTime       @default(now()) @map("claimed_at")
  firstContactedAt    DateTime?      @map("first_contacted_at")
  completedAt         DateTime?      @map("completed_at")
  createdAt           DateTime       @default(now()) @map("created_at")
  updatedAt           DateTime       @updatedAt @map("updated_at")

  broker               Broker?               @relation(fields: [brokerId], references: [id])
  lead                 Lead?                 @relation(fields: [leadId], references: [id])
  project              Project?              @relation(fields: [projectId], references: [id])
  unitBooking          UnitBooking?          @relation(fields: [unitBookingId], references: [id])
  documents            CaseDocument[]
  assistLogs           CaseAssistLog[]
  milestoneEvents      CaseMilestoneEvent[]
  attributionConflicts AttributionConflict[]

  @@index([brokerId, caseStatus])
  @@index([normalizedPhone, caseStatus])
  @@index([milestone])
  @@index([lockExpiresAt])
  @@map("noxh_cases")
}

model CaseDocument {
  id            String        @id @default(uuid())
  caseId        String        @map("case_id")
  docType       NoxhDocType   @map("doc_type")
  status        NoxhDocStatus @default(MISSING)
  receivedAt    DateTime?     @map("received_at")
  reviewedAt    DateTime?     @map("reviewed_at")
  passedAt      DateTime?     @map("passed_at")
  rejectReason  String?       @map("reject_reason") @db.Text
  ctvActionHint String?       @map("ctv_action_hint") @db.Text
  expiresAt     DateTime?     @map("expires_at")
  updatedBy     String?       @map("updated_by")
  createdAt     DateTime      @default(now()) @map("created_at")
  updatedAt     DateTime      @updatedAt @map("updated_at")

  noxhCase NoxhCase @relation(fields: [caseId], references: [id], onDelete: Cascade)

  @@unique([caseId, docType])
  @@index([caseId, status])
  @@map("case_documents")
}

model CaseAssistLog {
  id         String        @id @default(uuid())
  caseId     String        @map("case_id")
  brokerId   String        @map("broker_id")
  assistType CtvAssistType @map("assist_type")
  message    String        @db.Text
  createdAt  DateTime      @default(now()) @map("created_at")

  noxhCase NoxhCase @relation(fields: [caseId], references: [id], onDelete: Cascade)

  @@index([caseId])
  @@index([brokerId])
  @@map("case_assist_logs")
}

model CaseMilestoneEvent {
  id            String         @id @default(uuid())
  caseId        String         @map("case_id")
  fromMilestone NoxhMilestone? @map("from_milestone")
  toMilestone   NoxhMilestone  @map("to_milestone")
  milestoneSub  String?        @map("milestone_sub")
  opsNote       String?        @map("ops_note") @db.Text
  actor         String?
  createdAt     DateTime       @default(now()) @map("created_at")

  noxhCase NoxhCase @relation(fields: [caseId], references: [id], onDelete: Cascade)

  @@index([caseId])
  @@map("case_milestone_events")
}

/// Magnix inbound UID — store of record (ADR-013). Dedupe `normalized_key`.
model InboundUidLead {
  id             String   @id @default(uuid())
  uid            String
  uidSource      String   @map("uid_source")
  normalizedKey  String   @unique @map("normalized_key")
  capturedAt     DateTime @map("captured_at")
  text           String?  @db.Text
  segment        String   @default("unclassified")
  score          Int      @default(0)
  interestKey    String?  @map("interest_key")
  tags           Json     @default("[]")
  meta           Json     @default("{}")
  classifyMethod String   @default("regex") @map("classify_method")
  consentBasis   String?  @map("consent_basis")
  status         String   @default("classified")
  platformLeadId String?  @unique @map("platform_lead_id")
  createdAt      DateTime @default(now()) @map("created_at")
  updatedAt      DateTime @updatedAt @map("updated_at")

  platformLead Lead? @relation(fields: [platformLeadId], references: [id], onDelete: SetNull)

  @@index([uidSource, capturedAt])
  @@index([segment, score])
  @@map("inbound_uid_leads")
}

/// Thông báo in-app cho CTV/môi giới.
model BrokerNotification {
  id        String    @id @default(uuid())
  brokerId  String    @map("broker_id")
  type      String
  title     String
  body      String    @db.Text
  caseId    String?   @map("case_id")
  readAt    DateTime? @map("read_at")
  createdAt DateTime  @default(now()) @map("created_at")

  broker Broker @relation(fields: [brokerId], references: [id], onDelete: Cascade)

  @@index([brokerId, readAt])
  @@index([brokerId, createdAt])
  @@map("broker_notifications")
}

/// ADR-014 Phase 3 — catalog dịch vụ / khóa học Agent (unlock by quiz hoặc admin).
enum AgentServiceCategory {
  TRAINING
  LEGAL
  PRODUCT
}

enum AgentEntitlementStatus {
  LOCKED
  ACTIVE
  EXPIRED
  REVOKED
}

enum QuizAttemptStatus {
  IN_PROGRESS
  PASSED
  FAILED
}

model AgentService {
  id               String               @id @default(uuid())
  code             String               @unique
  category         AgentServiceCategory
  name             String
  description      String               @db.Text
  /// Nội dung học / pháp lý (markdown) — đọc trước khi thi.
  contentMarkdown  String?              @map("content_markdown") @db.Text
  isRequiredForCtv Boolean              @default(false) @map("is_required_for_ctv")
  /// Dịch vụ sản phẩm cần pass trainingCode trước (vd. NOXH_CLAIM ← CTV_ONBOARDING).
  requiresCode     String?              @map("requires_code")
  sortOrder        Int                  @default(0) @map("sort_order")
  active           Boolean              @default(true)
  createdAt        DateTime             @default(now()) @map("created_at")
  updatedAt        DateTime             @updatedAt @map("updated_at")

  entitlements AgentEntitlement[]
  quiz         AgentQuiz?

  @@index([category, sortOrder])
  @@map("agent_services")
}

model AgentEntitlement {
  id                  String                 @id @default(uuid())
  brokerId            String                 @map("broker_id")
  serviceId           String                 @map("service_id")
  status              AgentEntitlementStatus @default(LOCKED)
  source              String                 @default("locked") // locked | quiz_pass | admin | bypass
  activatedAt         DateTime?              @map("activated_at")
  trainingCompletedAt DateTime?              @map("training_completed_at")
  createdAt           DateTime               @default(now()) @map("created_at")
  updatedAt           DateTime               @updatedAt @map("updated_at")

  broker  Broker       @relation(fields: [brokerId], references: [id], onDelete: Cascade)
  service AgentService @relation(fields: [serviceId], references: [id], onDelete: Cascade)

  @@unique([brokerId, serviceId])
  @@index([brokerId, status])
  @@map("agent_entitlements")
}

model AgentQuiz {
  id        String   @id @default(uuid())
  serviceId String   @unique @map("service_id")
  title     String
  passScore Int      @default(70) @map("pass_score")
  version   Int      @default(1)
  active    Boolean  @default(true)
  createdAt DateTime @default(now()) @map("created_at")

  service   AgentService        @relation(fields: [serviceId], references: [id], onDelete: Cascade)
  questions AgentQuizQuestion[]
  attempts  QuizAttempt[]

  @@map("agent_quizzes")
}

model AgentQuizQuestion {
  id            String @id @default(uuid())
  quizId        String @map("quiz_id")
  prompt        String @db.Text
  /// [{ "id": "a", "label": "..." }, ...]
  optionsJson   Json   @map("options_json")
  correctOption String @map("correct_option")
  sortOrder     Int    @default(0) @map("sort_order")

  quiz AgentQuiz @relation(fields: [quizId], references: [id], onDelete: Cascade)

  @@index([quizId, sortOrder])
  @@map("agent_quiz_questions")
}

model QuizAttempt {
  id          String            @id @default(uuid())
  quizId      String            @map("quiz_id")
  brokerId    String            @map("broker_id")
  status      QuizAttemptStatus @default(IN_PROGRESS)
  score       Int?
  /// { questionId: optionId }
  answersJson Json?             @map("answers_json")
  startedAt   DateTime          @default(now()) @map("started_at")
  completedAt DateTime?         @map("completed_at")

  quiz   AgentQuiz @relation(fields: [quizId], references: [id], onDelete: Cascade)
  broker Broker    @relation(fields: [brokerId], references: [id], onDelete: Cascade)

  @@index([brokerId, quizId])
  @@map("quiz_attempts")
}
