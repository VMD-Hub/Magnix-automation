# PostgreSQL connection string used by Prisma.
# Local dev (docker compose): copy dòng dưới vào .env, rồi chạy `npm run db:setup`
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/housex?schema=public"

# Public base URL used for canonical/OG metadata on SSR pages.
# Local dev:
NEXT_PUBLIC_SITE_URL="http://localhost:3000"
# Production (timnhaxahoi.com — tạm thời, brand vẫn HouseX):
# NEXT_PUBLIC_SITE_URL="https://timnhaxahoi.com"

# Shared secret protecting the cron endpoint /api/cron/expire-listings (rule #5).
# Leave empty in local dev to disable the auth check.
CRON_SECRET=""

# Default commission rate (rule #4) — listing WON flow.
DEFAULT_COMMISSION_RATE="0.01"

# Hoa hồng CTV mặc định khi ký HĐMB NOXH (VND).
DEFAULT_NOXH_CTV_COMMISSION_AMOUNT="15000000"
# Ngày chờ CĐT xác nhận trước kỳ chi 05/20.
CDT_SETTLEMENT_DAYS="14"
# Cửa sổ lock CTV claim (ngày làm việc).
CTV_CLAIM_LOCK_BUSINESS_DAYS="20"
# Wizard tier HOT → auto NoxhCase platform (DNA-B). Mặc định true nếu không set.
NOXH_WIZARD_HOT_AUTO_CASE="true"

# Magnix inbound ingest — POST /api/ingest/magnix-lead
MAGNIX_INGEST_SECRET=""

# ADR-015 G2 Journey P — proposal/outcome/funnel (default off)
HOUSEX_CONVERSION_G2_JOURNEY_P="false"

# Sheet mirror (ADR-013 P2) — Postgres → tab ops_mirror, 1 chiều read-only
MAGNIX_SHEET_MIRROR_ENABLED="false"
GOOGLE_SHEET_MIRROR_ID=""
GOOGLE_SHEET_MIRROR_TAB="ops_mirror"
# Đường dẫn JSON service account (share Sheet Editor cho client_email)
GOOGLE_SERVICE_ACCOUNT_JSON=""
# Tab chi tiết wizard NOXH (backfill opsMeta.wizardSnapshot)
# NOXH_DETAIL_SHEET_TAB="noxh_leads_detail"
# SHEET_MIRROR_INBOUND_LIMIT=500
# SHEET_MIRROR_NOXH_LIMIT=300

# --- P0: attribution & anti-fraud ---
# Redis cho idempotency / click dedup / rate limit. Bỏ trống = fallback in-memory (chỉ dev).
REDIS_URL=""
# Cửa sổ khoá quyền sở hữu khách (ngày). Hết hạn → khách "tự do", broker mới được chiếm.
ATTRIBUTION_LOCK_DAYS="30"
# Rate limit POST /api/leads theo IP.
LEAD_RATE_MAX="20"
LEAD_RATE_WINDOW_SEC="3600"

# --- P1: content dedup ---
# Ngưỡng near-dupe SimHash (số bit khác nhau, 0–64). Mặc định 3.
CONTENT_NEAR_DUPE_BITS="3"

# --- P1: media pipeline ---
# stub (dev) | bunny | cloudflare
MEDIA_PROVIDER="stub"
MEDIA_WEBHOOK_SECRET=""
# Tiêu chuẩn chất lượng media.
MEDIA_MIN_IMAGE_PX="1024"
MEDIA_MIN_VIDEO_HEIGHT="720"
MEDIA_MIN_VIDEO_SEC="5"
MEDIA_MAX_VIDEO_SEC="120"
# Bunny Stream
BUNNY_STREAM_LIBRARY_ID=""
BUNNY_STREAM_API_KEY=""
BUNNY_STREAM_CDN_HOST="vz.b-cdn.net"
# Cloudflare Stream
CLOUDFLARE_ACCOUNT_ID=""
CLOUDFLARE_STREAM_TOKEN=""

# --- P2: quality gate & ranking ---
# Điều kiện đăng (publish gate) khi chuyển listing sang ACTIVE.
LISTING_MIN_PHOTOS="5"
LISTING_MIN_DESC_LEN="50"

# --- P2: event-driven outbox ---
# Dispatcher forward sự kiện sang n8n webhook. Bỏ trống = chỉ log (dev).
# Event types: lead.created (form dự án/tin đăng), lead.noxh_checked (công cụ NOXH),
# account.registered (đăng ký khách/môi giới), ctv.application_submitted, lead.won
EVENTS_WEBHOOK_URL=""
EVENTS_WEBHOOK_SECRET=""

# --- Công cụ NOXH: forward chi tiết tài chính (thu nhập, nợ xấu, DTI) sang n8n
# để lưu Google Sheet. KHÔNG lưu Postgres. Bỏ trống = không forward chi tiết.
NOXH_DETAIL_WEBHOOK_URL=""
# Ví dụ sau khi deploy n8n workflow housex-noxh-lead-route:
# EVENTS_WEBHOOK_URL=https://your-n8n.example/webhook/magnix/housex-events
# NOXH_DETAIL_WEBHOOK_URL=https://your-n8n.example/webhook/magnix/housex-noxh-detail

# --- P1: search & geo ---
# Meilisearch self-host. Bỏ trống = fallback truy vấn DB (dev / chưa có search server).
MEILI_HOST=""
MEILI_MASTER_KEY=""
# Geo mặc định chạy bằng bounding-box + haversine (không cần PostGIS).
# Lên quy mô lớn: chạy prisma/sql/enable-postgis.sql rồi chuyển sang ST_DWithin.

# --- Lớp 1: bảo mật số điện thoại ---
# Số điện thoại môi giới chỉ hiển thị cho user đã đăng nhập (cookie hx_session đã ký).
# Rate limit reveal để chống cào số hàng loạt.
PHONE_REVEAL_MAX="30"
PHONE_REVEAL_WINDOW_SEC="3600"
# Cloudflare Turnstile trước reveal SĐT (production). Dev: bỏ trống = không bắt captcha.
NEXT_PUBLIC_TURNSTILE_SITE_KEY=""
TURNSTILE_SECRET_KEY=""

# --- Chống scrape Phase 1 ---
# SCRAPE_GUARD_ENABLED=false để tắt (dev). Rate limit dùng REDIS_URL (production bắt buộc).
SCRAPE_GUARD_ENABLED="true"
BROWSE_RATE_MAX="180"
BROWSE_RATE_WINDOW_SEC="60"
SEARCH_API_RATE_MAX="60"
SEARCH_API_RATE_WINDOW_SEC="60"
LISTINGS_API_RATE_MAX="60"
LISTINGS_API_RATE_WINDOW_SEC="60"

# --- Lớp 1: đăng nhập khách (Customer) ---
# Bắt buộc trên production — dùng ký cookie phiên.
AUTH_SECRET=""
# Rate limit đăng nhập/đăng ký theo IP.
AUTH_RATE_MAX="10"
AUTH_RATE_WINDOW_SEC="900"

# --- ADR-014: Zalo Mini App auth ---
# App ID / Secret từ developers.zalo.me (KHÔNG commit giá trị thật).
ZALO_APP_ID=""
ZALO_APP_SECRET=""
# OA ID (tuỳ chọn — deep link / push sau).
ZALO_OA_ID=""
# DNA-D: OA CS — chỉ bật khi cần tin quảng bá/chiến dịch (không dùng cho notify hệ thống CTV).
# CTV nhận milestone/conflict qua in-app Mini App (/agent/thong-bao) — miễn phí.
ZALO_OA_NOTIFY_ENABLED="false"
# Phase 2 telesales — gửi OA/SMS từ server (mặc định tắt; bật khi consent + OA/SMS sẵn sàng).
TELESALES_SERVER_SEND_ENABLED="false"
# SMS qua n8n — thiếu URL → channel sms ghi NurtureDispatch SKIPPED.
SMS_WEBHOOK_URL=""
SMS_WEBHOOK_SECRET=""
# Round 2 Wave 3 — sink nội bộ (không gửi carrier). Chỉ bật khi smoke:
# SMOKE_SMS_SINK_ENABLED="true"
# SMS_WEBHOOK_URL="http://127.0.0.1:3000/api/admin/smoke/sms-webhook-sink"
# rồi tắt cả hai sau smoke + pm2 restart.
# Smoke: ZALO_OA_TEST_USER_ID=<zalo_user_id> npm run go-live:smoke-zalo-oa
# Callback OAuth OA (mặc định = NEXT_PUBLIC_SITE_URL + /api/zalo/oa/callback).
# ZALO_OA_CALLBACK_URL="https://timnhaxahoi.com/api/zalo/oa/callback"
# Refresh token OA (khuyến nghị) — lấy qua /api/zalo/oa/authorize sau khi đăng ký Callback trên developers.
ZALO_OA_REFRESH_TOKEN=""
# Dev ngắn hạn (~25h): API Explorer → OA Access Token trên developers.zalo.me
# ZALO_OA_ACCESS_TOKEN=""
# P4 campaign subdomain → hub (mặc định noxh/cctm.timnhaxahoi.com trong code)
# CAMPAIGN_LANE_HOSTS="promo.example.com=/du-an/thuong-mai"
# Chỉ local: cho phép POST /api/auth/zalo với { zaloUserId, phone } bỏ Graph.
# ZALO_AUTH_DEV_BYPASS="true"
# SĐT test được phép gỡ zaloUserId: npm run ops:unbind-zalo-phone -- --yes 09...
# OPS_TEST_PHONES="+84915779711,+84826600800,+84825500800"
# Rate limit quên mật khẩu theo IP.
AUTH_FORGOT_MAX="5"
AUTH_FORGOT_WINDOW_SEC="3600"

# --- Email transactional (xác nhận tài khoản, đặt lại mật khẩu, thông báo sau này) ---
# Khuyến nghị Magnix: n8n webhook nhận payload và gửi qua SMTP/Gmail API.
EMAIL_WEBHOOK_URL=""
EMAIL_WEBHOOK_SECRET=""
# Hoặc Resend trực tiếp (https://resend.com).
RESEND_API_KEY=""
# Email hiển thị public (footer, liên hệ). Mặc định: vunguyen@timnhaxahoi.com
NEXT_PUBLIC_SUPPORT_EMAIL=""
# NEXT_PUBLIC_SUPPORT_PHONE="0826 600 800"

# Email pháp lý / biên tập (trang /dieu-khoan)
# NEXT_PUBLIC_LEGAL_EMAIL="legal@timnhaxahoi.com"
# NEXT_PUBLIC_EDITORIAL_EMAIL="editorial@timnhaxahoi.com"
# NEXT_PUBLIC_LEGAL_ADDRESS="37 Đường số 12, Bình Trưng, TP. Hồ Chí Minh"
# Chủ thể pháp lý vận hành House X (footer, Điều khoản, Zalo OA)
# NEXT_PUBLIC_LEGAL_ENTITY_NAME="Công ty TNHH Minh An Land"
# NEXT_PUBLIC_LEGAL_ENTITY_NAME_EN="Minh An Land Co., Ltd."

# Mạng xã hội — thêm URL khi sẵn sàng (hiện hiển thị "sắp có")
NEXT_PUBLIC_SOCIAL_ZALO_URL=""
NEXT_PUBLIC_SOCIAL_FACEBOOK_URL=""
NEXT_PUBLIC_SOCIAL_TIKTOK_URL=""
NEXT_PUBLIC_SOCIAL_YOUTUBE_URL=""

# Ảnh chân dung Founder (Leo Duong) — khối lời phát biểu About / Câu chuyện.
# Bỏ trống = placeholder initials "LD". Đặt file vào public/ hoặc CDN.
# NEXT_PUBLIC_FOUNDER_PORTRAIT_URL="/images/team/leo-duong-founder.jpg"

# Vũ Nguyễn — digital profile / NFC (Lớp 3 Personal Brand) · /vu-nguyen
# NEXT_PUBLIC_VU_NGUYEN_PORTRAIT_URL="/brand/vu-nguyen/portrait.png"
# NEXT_PUBLIC_VU_NGUYEN_VIDEO_URL=""
# NEXT_PUBLIC_VU_NGUYEN_ZALO_URL="https://zalo.me/0826600800"
# NEXT_PUBLIC_VU_NGUYEN_LINKEDIN_URL="https://www.linkedin.com/in/vu-n-506256408"
# NEXT_PUBLIC_VU_NGUYEN_TELEGRAM_URL="https://t.me/..."
# Link Mini App — deep link từ QR developers.zalo.me (ưu tiên hơn OA / SĐT cá nhân)
# NEXT_PUBLIC_ZALO_MINIAPP_URL="https://zalo.me/s/1554712272702750699/?utm_source=zalo-qr"
# NEXT_PUBLIC_ZALO_MINIAPP_ID="1554712272702750699"
# Link Zalo OA public (trang OA — khác Mini App direct link)
# NEXT_PUBLIC_ZALO_OA_PUBLIC_URL="https://zalo.me/<OA_ID>"
# NEXT_PUBLIC_ZALO_OA_ID="<OA_ID>"
# QR in thẻ: npm run brand:vu-nguyen-qr → public/brand/vu-nguyen/qr/

# Ảnh thành viên ban lãnh đạo (trang /doi-ngu) — hoặc sửa portraitSrc trong team-editorial-content.ts
# NEXT_PUBLIC_TEAM_PORTRAIT_NGUYEN_THANH_VU="/images/team/nguyen-thanh-vu.jpg"
# NEXT_PUBLIC_TEAM_PORTRAIT_NGUYEN_GIA_VIET="/images/team/nguyen-gia-viet.jpg"

# Con số nổi bật trang Giới thiệu (bỏ trống = hiển thị "—")
# NEXT_PUBLIC_METRIC_VERIFIED_LISTINGS="1.240"
# NEXT_PUBLIC_METRIC_MONTHLY_USERS="8.500"
# NEXT_PUBLIC_METRIC_ACTIVE_PROJECTS="45"
# NEXT_PUBLIC_METRIC_BROKER_PARTNERS="120"
# EMAIL_FROM="HouseX <noreply@timnhaxahoi.com>"
EMAIL_FROM=""
# --- Console vận hành nền tảng (/admin/login) — không phải admin group Zalo ---
# ADMIN_SECRET = Chủ quản (Super): duyệt tin, CTV, landing, promotion…
ADMIN_SECRET=""
# ADMIN_OPS_SECRET = Ops (tùy chọn): lead marketing, conflict, inbound, NOXH case
ADMIN_OPS_SECRET=""
