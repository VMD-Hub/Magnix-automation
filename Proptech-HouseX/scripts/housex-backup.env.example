# Install as /etc/housex/backup.env, owned root:root and mode 0600.
# Never commit the populated file or rclone.conf.

HOUSEX_BACKUP_SCRIPT=/usr/local/libexec/housex-backup/backup-postgres-vps.sh
HOUSEX_BACKUP_DIR=/root/backup/housex
HOUSEX_BACKUP_RETENTION_DAYS=14
HOUSEX_BACKUP_REQUIRE_OFFSITE=true
HOUSEX_PG_CONTAINER=housex-postgres
HOUSEX_PG_USER=housex
HOUSEX_PG_NAME=housex

# This must name an rclone remote whose actual configured type is "crypt".
# "housex-drive:postgres" is rejected even if its name sounds encrypted.
RCLONE_CONFIG=/root/.config/rclone/rclone.conf
HOUSEX_BACKUP_RCLONE_REMOTE=housex-crypt:postgres
HOUSEX_BACKUP_OFFSITE_HOOK=/usr/local/libexec/housex-backup/housex-backup-offsite-upload.sh
HOUSEX_BACKUP_OFFSITE_VERIFY_HOOK=/usr/local/libexec/housex-backup/housex-backup-offsite-verify.sh

# Populate only in /etc/housex/backup.env.
MAGNIX_TELEGRAM_NOTIFY_WEBHOOK_URL=
MAGNIX_WEBHOOK_TOKEN=
