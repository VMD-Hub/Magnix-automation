!.yarn/plugins
!.yarn/releases
!.yarn/versions

# testing
/coverage

# next.js
/.next/
/out/

# production
/build

# misc
.DS_Store
*.pem

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# env files (can opt-in for committing if needed)
.env*
!.env.example

# vercel
.vercel

# typescript
*.tsbuildinfo
next-env.d.ts

# broker listing uploads (VPS local — migrate CDN sau)
/public/uploads/

# Zalo OA refresh token sau rotate (auto-write, không commit)
.zalo-oa-refresh

# Local/VPS smoke & KPI reports (IDs only — still keep out of git)
/reports/

# Logo patch backups (scripts/patch-housex-logo-domain-tagline.ts)
/public/brand/*.pre-domain-tagline.bak.png
