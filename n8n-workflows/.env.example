# n8n env — Magnix (Google Sheet primary + Drive archive)

MAGNIX_STORAGE_MODE=google_sheet_primary_drive_archive

# Tên Page Facebook trong disclaimer (ưu tiên hơn MAGNIX_BRAND_NAME)
MAGNIX_PAGE_DISPLAY_NAME=Tim Nha O Xa Hoi

# Brand fallback nếu không set MAGNIX_PAGE_DISPLAY_NAME
MAGNIX_BRAND_NAME=Magnix

# Link tải lead magnet cho CTA blog_seo (Content Type Router)
MAGNIX_OFFER_LINK_NOXH=
MAGNIX_OFFER_LINK_DONGTIEN=
MAGNIX_OFFER_LINK_DINHGIA=

# Webhook auth (optional — để trống = tắt check)
MAGNIX_WEBHOOK_TOKEN=

# Agent 7 — video TTS webhook (ElevenLabs) · xem VIDEO_TTS_SETUP.md
MAGNIX_VIDEO_TTS_URL=http://103.57.221.93:8765
PEXELS_API_KEY=
CREATOMATE_DISABLE_VOICE=false
CREATOMATE_VOICE_PROVIDER=google

# DeepSeek — LLM chính (rẻ): classify, Layer B, outreach, video script
DEEPSEEK_API_KEY=
DEEPSEEK_API_URL=https://api.deepseek.com/chat/completions
DEEPSEEK_MODEL=deepseek-chat

# Anthropic — fallback + Agent 3 segment pháp lý L2 (noxh/vay/định giá)
# Override theo task: MAGNIX_LLM_<TASK>_PROVIDER=deepseek|anthropic
# Task: CLASSIFY, EDITORIAL_BRIEF, OUTREACH, VIDEO_DRAFT, CONTENT_DRAFT, CONTENT_DRAFT_GENERAL

# Google Sheet — store of record + ops queues / content review
GOOGLE_SHEET_DATABASE_ID=
GOOGLE_SHEET_UID_TAB=uid_leads
GOOGLE_SHEET_CONTENT_QUEUE_TAB=content_queue
GOOGLE_SHEET_CONTENT_DRAFTS_TAB=content_drafts
GOOGLE_SHEET_VIDEO_DRAFTS_TAB=video_drafts
GOOGLE_SHEET_OUTREACH_TAB=outreach_queue
GOOGLE_SHEET_NOTIFICATION_EVENTS_TAB=notification_events

# Content scorecard — Mạch 5 (xem CONTENT_SCORECARD_SETUP.md)
GOOGLE_SHEET_CONTENT_METRICS_ID=
GOOGLE_SHEET_CONTENT_METRICS_TAB=content_metrics
GOOGLE_SHEET_CONTENT_SCORECARD_TAB=content_scorecard
GOOGLE_SHEET_PROJECT_CONFIG_TAB=project_config

# Agent 1 — Apify + Claude
APIFY_TOKEN=
APIFY_RUN_URL=https://api.apify.com/v2/acts/clockworks~tiktok-scraper/run-sync-get-dataset-items
APIFY_MAX_ITEMS=3
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-sonnet-4-6
ANTHROPIC_DRAFT_MODEL=claude-sonnet-4-6
ANTHROPIC_CLASSIFY_MODEL=claude-haiku-4-5-20251001

# Google Drive JSON archive (xem DRIVE_BACKUP_SETUP.md)
GOOGLE_DRIVE_ARCHIVE_FOLDER_ID=
GOOGLE_SERVICE_ACCOUNT_JSON=./credentials/google-service-account.json
MAGNIX_DRIVE_BACKUP=true

# n8n REST API — push workflow từ local (Settings → API trên n8n.vmd.asia)
N8N_PUBLIC_URL=https://n8n.vmd.asia
N8N_API_KEY=

# Telegram L3 approval (workflow telegram-notify / reminder / resolver)
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID_OWNER=
TELEGRAM_CHAT_ID_OPS=
TELEGRAM_APPROVAL_ENABLED=true
TELEGRAM_REMINDER_ENABLED=true

# Facebook Page publish (workflow content-page-publish — xem docs/CONTENT_PAGE_PUBLISH_SETUP.md)
# META_PAGE_ID = Page ID (About → Page ID), KHÔNG phải App ID
# META_PAGE_ACCESS_TOKEN = Page Access Token (EAA…) với quyền pages_manage_posts + pages_read_engagement
# DRIVE_NOXH_TEMPLATES_PUBLIC_URL = link folder mẫu (init-magnix-drive-noxh-templates.mjs)
CONTENT_PAGE_PUBLISH_ENABLED=false
META_PAGE_ID=
META_PAGE_ACCESS_TOKEN=
META_GRAPH_API_VERSION=v21.0
DRIVE_NOXH_TEMPLATES_FOLDER_ID=
DRIVE_NOXH_TEMPLATES_PUBLIC_URL=

# Facebook Page cover (workflow content-page-cover — xem docs/CONTENT_PAGE_COVER_SETUP.md)
CONTENT_PAGE_COVER_ENABLED=false
GEMINI_API_KEY=
# Hoặc đặt key trong n8n-workflows/.env.local (gitignored)
GEMINI_IMAGE_MODEL=gemini-2.5-flash-image
PAGE_COVER_ASPECT_RATIO=1:1
DRIVE_PAGE_COVERS_FOLDER_ID=

# Gemini (thay HTTP LLM node — tùy chỉnh UI)
